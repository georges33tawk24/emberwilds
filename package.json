{
  "name": "emberwilds",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EMBERWILDS — a warm, hand-crafted 2D action-platformer for the web",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/stampSw.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:assets": "node scripts/genAppAssets.mjs && npx @capacitor/assets generate --splashBackgroundColor '#14100d' --iconBackgroundColor '#2A1F1B'"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
